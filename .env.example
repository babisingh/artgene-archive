# ArtGene Archive — Environment Variables
# ──────────────────────────────────────────────────────────────────
# LOCAL DEV:    copy to .env and fill in values
# RAILWAY:      set these in each service's Variables tab
#               (Railway injects DATABASE_URL automatically for the
#                Postgres plugin — no need to set it manually there)
# ──────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────
# Local dev default. Railway: provided automatically by the Postgres plugin.
DATABASE_URL=postgresql://postgres:tinsel_local_password@localhost:5432/artgene

# ── TINSEL Spreading Key ──────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
# REQUIRED in production — app refuses to start with the dev default
# when SENTINEL_ENV=production.
SPREADING_KEY=REPLACE_WITH_64_CHAR_HEX_STRING
SPREADING_KEY_ID=local-dev-key

# ── Runtime ───────────────────────────────────────────────────────
# development  — uses mock biosafety gates, dev spreading key allowed
# production   — uses real gates, SPREADING_KEY must not be the default
SENTINEL_ENV=development
LOG_LEVEL=INFO

# ── CORS ──────────────────────────────────────────────────────────
# Railway: set to your dashboard service's public URL
# e.g. ALLOWED_ORIGINS=https://artgene-dashboard.up.railway.app
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ── Dashboard (build-time variable) ──────────────────────────────
# Railway dashboard service: set this as a BUILD VARIABLE (not runtime)
# pointing to your Railway API service public URL.
# e.g. NEXT_PUBLIC_API_URL=https://artgene-api.up.railway.app
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── External APIs (production only) ──────────────────────────────
NCBI_EMAIL=your@email.com
NCBI_API_KEY=
ESMFOLD_API_URL=https://api.esmatlas.com/foldSequence/v1/pdb/

# ── AWS (only if using AWS Secrets Manager vault) ─────────────────
AWS_REGION=eu-west-1
AWS_ACCOUNT_ID=
