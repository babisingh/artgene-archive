# artGene-archive · Environment Variables
# Copy this to .env and fill in the values

# ── Database ──────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:tinsel_local_password@localhost:5432/artgene

# ── TINSEL Spreading Key ─────────────────────────────────────────
# For LOCAL development only: generate with `python -c "import secrets; print(secrets.token_hex(32))"`
# For AWS: set SPREADING_KEY_ID to the Secrets Manager ARN instead
SPREADING_KEY=FILL_IN_32_BYTE_HEX_KEY_HERE
SPREADING_KEY_ID=local-dev-key

# ── AWS (production only) ─────────────────────────────────────────
AWS_REGION=eu-west-1
AWS_ACCOUNT_ID=FILL_IN
# AWS credentials via IAM role (Lambda) or ~/.aws/credentials (local)

# ── External APIs ─────────────────────────────────────────────────
# NCBI BLAST (register free at https://www.ncbi.nlm.nih.gov/)
NCBI_EMAIL=FILL_IN_YOUR_EMAIL@domain.com
NCBI_API_KEY=FILL_IN_OR_LEAVE_EMPTY

# ESMFold (Meta — free, no key needed for basic usage)
ESMFOLD_API_URL=https://api.esmatlas.com/foldSequence/v1/pdb/

# ── Runtime ───────────────────────────────────────────────────────
# Options: test (mock all external APIs) | development | production
SENTINEL_ENV=development
LOG_LEVEL=INFO

# ── CORS ────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
