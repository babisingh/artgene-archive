# ─────────────────────────────────────────────────────────────────────────────
# ArtGene / Tinsel — environment variables
# Copy this file to .env and fill in real values. Never commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ──────────────────────────────────────────────────────────────
ENV=development
LOG_LEVEL=debug

# ── API ──────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_SECRET_KEY=change-me-in-production

# ── Dashboard (Next.js public vars must be prefixed NEXT_PUBLIC_) ─────────────
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── Redis (job queue / caching) ───────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── AWS (Lambda / S3 — required in production) ───────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_RESULTS_BUCKET=artgene-results-dev

# ── External gate services (leave empty to use mock adapters) ─────────────────
ESMFOLD_API_URL=
NCBI_BLAST_API_KEY=
TOXINPRED_API_URL=

# ── Feature flags ─────────────────────────────────────────────────────────────
USE_MOCK_ADAPTERS=true
GATE_PARALLEL=true
